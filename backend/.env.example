# --- Server ---
PORT=3000
NODE_ENV=production

# --- Database (MongoDB Atlas free M0 cluster) ---
# Get this from Atlas: Database > Connect > Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ait?retryWrites=true&w=majority

# --- Telegram Bot ---
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenFromBotFather
# Public URL of your deployed Mini App frontend (Vercel URL)
MINI_APP_URL=https://your-ait-app.vercel.app
# Your Telegram channel's @username or numeric chat ID. The bot MUST be added
# as an admin of this channel (member-level access is enough) so it can call
# getChatMember to verify users actually joined before paying the mission reward.
TELEGRAM_CHANNEL_ID=@your_ait_channel

# --- Auth / Security ---
# Random long string used to sign session JWTs issued to the mini app frontend
JWT_SECRET=change-this-to-a-long-random-string

# --- Admin ---
# Comma-separated Telegram numeric user IDs allowed into the admin dashboard
ADMIN_TELEGRAM_IDS=111111111,222222222
# Fallback username/password login (used for the admin web login form)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
# Secret used to sign admin session JWTs (different from JWT_SECRET above)
ADMIN_JWT_SECRET=change-this-to-a-different-long-random-string

# --- CORS ---
# Comma-separated list of allowed origins (your Vercel frontend + admin URLs)
ALLOWED_ORIGINS=https://your-ait-app.vercel.app,https://your-ait-admin.vercel.app
